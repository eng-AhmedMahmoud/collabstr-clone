{
  "name": "collabstr-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "web": "pnpm --filter @collabstr/web",
    "api": "pnpm --filter @collabstr/api",
    "db:migrate": "pnpm --filter @collabstr/api prisma:migrate",
    "db:seed": "pnpm --filter @collabstr/api seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.32.1"
}
